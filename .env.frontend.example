# Shared frontend environment — copy to web/.env AND web-public/.env (identical files).
# Or copy once to repo root as .env and symlink to both app folders.
#
#   cp .env.frontend.example web/.env
#   cp .env.frontend.example web-public/.env
#
# server-php uses its own .env (see server-php/.env.example for GA4 property IDs).

# ─── Marketing site (web-public → carahulgupta.in) ───────────────────────────
VITE_PORTAL_URL=https://app.carahulgupta.in
# VITE_API_BASE_URL=http://localhost:8080/api

# ─── Office portal (web → app.carahulgupta.in) ─────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api
VITE_MARKETING_URL=https://carahulgupta.in
VITE_GOOGLE_CLIENT_ID=
VITE_MSAL_CLIENT_ID=
VITE_MSAL_TENANT_ID=common

# ─── GA4 (optional) — separate properties recommended ────────────────────────
# G-… from GA4 → Admin → Data streams → Web (not OAuth client ID).
VITE_GA4_MARKETING_MEASUREMENT_ID=
VITE_GA4_PORTAL_MEASUREMENT_ID=
# Single property on both domains: set only this legacy fallback:
# VITE_GA4_MEASUREMENT_ID=
