# ─── Backend API ──────────────────────────────────────────────────────────────
# Base URL of the PHP REST API (no trailing slash).
# Points to server-php/public/ — wherever /admin/... requests are served (no trailing slash).
# Local dev:   http://localhost:8080/api
# Production:  https://carahulgupta.in/api  (cPanel — API deployed in the /api subfolder)
# If this is NOT set the app runs in mock/dev mode:
#   • Email OTP accepts "123456" as the valid code.
#   • Social logins use dummy tokens and the email returned by the provider.
VITE_API_BASE_URL=http://localhost:8080/api

# When true, matches PHP LEDGER_USER_REVERSAL_ENABLED — user email OTP + 30-day window for reversals.
VITE_LEDGER_USER_REVERSAL_ENABLED=true

# ─── Cloudflare Turnstile (public blog lead form) ─────────────────────────────
# Create a widget at https://dash.cloudflare.com/ → Turnstile
# Site key (public, used in BlogCTA). Secret key goes in server-php/.env as TURNSTILE_SECRET_KEY.
# Leave blank in local dev — CAPTCHA is skipped when either key is unset.
VITE_TURNSTILE_SITE_KEY=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Set the Authorised JavaScript Origin to your domain (e.g. https://yourdomain.com).
VITE_GOOGLE_CLIENT_ID=

# ─── Microsoft / Outlook OAuth (MSAL) ────────────────────────────────────────
# Register an application at https://portal.azure.com/
# → Azure Active Directory → App Registrations → New registration
# Add a Redirect URI of type "Single-Page Application" matching EXACTLY:
#   https://<your-domain>/<base-path>/   (include trailing slash)
#
# Client ID  (Application (client) ID from the Overview page)
VITE_MSAL_CLIENT_ID=
#
# Tenant ID  (Directory (tenant) ID — use "common" to allow any Microsoft account)
VITE_MSAL_TENANT_ID=common

# ─── Public Marketing Site ───────────────────────────────────────────────────
# URL of the public marketing site (carahulgupta.in) used by the "Wrong portal?"
# escape link on the locked-portal login page. Defaults to https://carahulgupta.in
# if unset.
VITE_MARKETING_URL=https://carahulgupta.in

# ─── Google Analytics 4 (optional) ───────────────────────────────────────────
# Measurement ID from GA4 → Admin → Data streams → Web (format G-XXXXXXXXXX).
# Use the SAME value in web-public/.env so carahulgupta.in and app.carahulgupta.in
# report to one property. Not the OAuth client ID above (VITE_GOOGLE_CLIENT_ID).
# Leave empty to disable client-side tracking (no-op in src/utils/analytics.js).
# Staff Traffic Analytics also needs GA4_PROPERTY_ID on server-php (see .env.example there).
VITE_GA4_MEASUREMENT_ID=
