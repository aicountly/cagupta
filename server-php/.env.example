# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── Document storage (KYC files) ─────────────────────────────────────────────
# REQUIRED in production: set to an absolute path OUTSIDE public_html so that
# uploaded KYC documents are never web-accessible by direct URL.
# Example: DOCU_BANK_PATH=/home/carahulgupta/docu_bank
# On local dev you can leave this unset; files go to {repo_root}/docu_bank.
DOCU_BANK_PATH=
APP_KEY=base64:changeme
BASE_URL=http://localhost:8080

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cagupta_db
# cPanel PostgreSQL user for this account (default in app/Config/Database.php)
DB_USER=carahulgupta_cagupta_user
DB_PASS=your_password
# Local Docker / dev: use DB_USER=postgres (or your role) instead.
# If DB_USER is a non-superuser role, grant privileges (run from server-php):
#   php database/print_app_grants.php | psql -h ... -U postgres -d ...
# Or edit app_role in database/migrations/029_app_pg_grants.sql and apply it.
#
# ── Migration-only credentials (cPanel) ────────────────────────────────────────
# On cPanel, DB_USER is a restricted role that does not own the tables, so
# ALTER TABLE migrations fail with "must be owner of table …".
# Set MIGRATION_DB_USER to the table-owner role (the phpPgAdmin default user,
# e.g. carahulgupta) and MIGRATION_DB_PASS to its password.
# database/migrate.php uses these when present; all runtime app connections
# still use DB_USER above. Leave blank on local dev (DB_USER is used instead).
MIGRATION_DB_USER=carahulgupta
MIGRATION_DB_PASS=owner_password_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: php -r "echo base64_encode(random_bytes(32));"
JWT_SECRET=your_jwt_secret_here
TOKEN_TTL_HOURS=8

# ─── CORS (browser Origins that may call this API; comma-separated in production) ─
# Production example: https://app.carahulgupta.in,https://carahulgupta.in
CORS_ORIGIN=http://localhost:5173

# ─── Brevo (email) ────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=office@carahulgupta.in
SENDER_NAME=CA Rahul Gupta Office
SUPERADMIN_NOTIFY_EMAIL=rahul@cagupta.in

# Required to request an OTP before saving quotation defaults (engagement-type catalog)
QUOTATION_SETUP_PASSPHRASE=change_me_strong_secret

# ─── Razorpay (online payments) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Register webhook URL: {BASE_URL}/api/webhooks/razorpay — event: payment.captured

# ─── Zoom OAuth (video appointments) ──────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Optional; defaults to {BASE_URL}/api/integrations/zoom/callback
ZOOM_REDIRECT_URI=
# HMAC secret for OAuth state (set a long random string in production)
ZOOM_STATE_SECRET=change_me_zoom_state

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Scopes: https://www.googleapis.com/auth/calendar openid email profile
# Authorised redirect URI: {BASE_URL}/api/integrations/calendar/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; auto-derived from BASE_URL if left blank
GOOGLE_REDIRECT_URI=

# ─── Microsoft / Outlook Calendar OAuth ──────────────────────────────────────
# Register app at portal.azure.com → App registrations
# Scopes: Calendars.ReadWrite offline_access User.Read
# Redirect URI: {BASE_URL}/api/integrations/calendar/outlook/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional; auto-derived from BASE_URL if left blank
MICROSOFT_REDIRECT_URI=

# HMAC secret for calendar OAuth state tokens (set a long random string in production)
CALENDAR_STATE_SECRET=change_me_calendar_state

# ─── Apple Calendar (CalDAV) ──────────────────────────────────────────────────
# No server-side keys needed — users supply their own Apple ID + App-Specific Password.
# Users generate App-Specific Passwords at: appleid.apple.com → Security → App-Specific Passwords
