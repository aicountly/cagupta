# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_KEY=base64:changeme
BASE_URL=http://localhost:8080

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cagupta_db
DB_USER=postgres
DB_PASS=your_password

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: php -r "echo base64_encode(random_bytes(32));"
JWT_SECRET=your_jwt_secret_here
TOKEN_TTL_HOURS=8

# ─── CORS (React frontend origin) ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Brevo (email) ────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
SENDER_EMAIL=no-reply@cagupta.in
SENDER_NAME=CA Gupta Office
