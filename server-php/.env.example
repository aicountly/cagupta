# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development

# ─── Document storage (KYC files) ─────────────────────────────────────────────
# REQUIRED in production: set to an absolute path OUTSIDE public_html so that
# uploaded KYC documents are never web-accessible by direct URL.
# Example: DOCU_BANK_PATH=/home/carahulgupta/docu_bank
# On local dev you can leave this unset; files go to {repo_root}/docu_bank.
DOCU_BANK_PATH=

# Blog cover images (separate from docu_bank / KYC). Absolute path outside public_html.
# cPanel example: BLOG_UPLOADS_PATH=/home/carahulgupta/blog_uploads
# Unset locally: files go to server-php/blog_uploads. Served via GET /api/public/blog-covers/{filename}.
BLOG_UPLOADS_PATH=

APP_KEY=base64:changeme
# Local dev: http://localhost:8080  |  Production: https://carahulgupta.in/api
BASE_URL=http://localhost:8080

# When true, staff with invoices.delete may reverse receipt/payment/TDS within 30 days using OTP to their own email.
LEDGER_USER_REVERSAL_ENABLED=true

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
# Local dev: cagupta_db  |  cPanel: carahulgupta_cagupta_db
DB_NAME=cagupta_db
# cPanel PostgreSQL user for this account (default in app/Config/Database.php)
DB_USER=carahulgupta_cagupta_user
DB_PASS=your_password
# Local Docker / dev: use DB_USER=postgres (or your role) instead.
# If DB_USER is a non-superuser role, grant privileges (run from server-php):
#   php database/print_app_grants.php | psql -h ... -U postgres -d ...
# Or edit app_role in database/migrations/029_app_pg_grants.sql and apply it.
#
# ── Migration-only credentials (cPanel) ────────────────────────────────────────
# On cPanel, DB_USER is a restricted role that does not own the tables, so
# ALTER TABLE migrations fail with "must be owner of table …".
# Set MIGRATION_DB_USER to the table-owner role (the phpPgAdmin default user,
# e.g. carahulgupta) and MIGRATION_DB_PASS to its password.
# database/migrate.php uses these when present; all runtime app connections
# still use DB_USER above. Leave blank on local dev (DB_USER is used instead).
MIGRATION_DB_USER=carahulgupta
MIGRATION_DB_PASS=owner_password_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: php -r "echo base64_encode(random_bytes(32));"
JWT_SECRET=your_jwt_secret_here
TOKEN_TTL_HOURS=8

# ─── CORS (browser Origins that may call this API; comma-separated in production) ─
# Production: https://app.carahulgupta.in,https://carahulgupta.in,https://www.carahulgupta.in
CORS_ORIGIN=http://localhost:5173

# ─── Brevo (email) ────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
# Concurrent Brevo API connections for blog email blasts (curl_multi). Default 12, max 30. Lower if Brevo returns 429/rate-limit errors.
# BREVO_SEND_CONCURRENCY=12
SENDER_EMAIL=office@carahulgupta.in
SENDER_NAME=CA Rahul Gupta Office
SUPERADMIN_NOTIFY_EMAIL=rahul@cagupta.in

# Required to request an OTP before saving quotation defaults (engagement-type catalog)
QUOTATION_SETUP_PASSPHRASE=change_me_strong_secret

# ─── Razorpay (online payments) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Register webhook URL: {BASE_URL}/api/webhooks/razorpay — event: payment.captured

# ─── Zoom OAuth (video appointments) ──────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Optional; defaults to {BASE_URL}/api/integrations/zoom/callback
ZOOM_REDIRECT_URI=
# HMAC secret for OAuth state (set a long random string in production)
ZOOM_STATE_SECRET=change_me_zoom_state

# ─── Portal OAuth — Google Sign-In token verification ─────────────────────────
# The portal frontend sends a Google ID token to the PHP backend for verification.
# Use the SAME client ID you set in web/.env as VITE_GOOGLE_CLIENT_ID.
# Also reused by Google Calendar OAuth below (same credential, same project).
GOOGLE_CLIENT_ID=

# ─── Portal OAuth — Microsoft / MSAL Sign-In token verification ──────────────
# The portal frontend sends a Microsoft ID token; PHP verifies it against these.
# Use the SAME values you set in web/.env as VITE_MSAL_CLIENT_ID / VITE_MSAL_TENANT_ID.
MSAL_CLIENT_ID=
MSAL_TENANT_ID=common

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
# Enables staff to connect their Google Calendar for appointment sync.
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Scopes: https://www.googleapis.com/auth/calendar openid email profile
# Authorised redirect URI: {BASE_URL}/api/integrations/calendar/google/callback
# GOOGLE_CLIENT_ID is shared with Portal OAuth above — only one credential needed.
GOOGLE_CLIENT_SECRET=
# Optional; auto-derived from BASE_URL if left blank
GOOGLE_REDIRECT_URI=

# ─── Microsoft / Outlook Calendar OAuth ──────────────────────────────────────
# Enables staff to connect their Outlook Calendar for appointment sync.
# Register app at portal.azure.com → App registrations
# Scopes: Calendars.ReadWrite offline_access User.Read
# Redirect URI: {BASE_URL}/api/integrations/calendar/outlook/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional; auto-derived from BASE_URL if left blank
MICROSOFT_REDIRECT_URI=

# HMAC secret for calendar OAuth state tokens (set a long random string in production)
CALENDAR_STATE_SECRET=change_me_calendar_state

# ─── Apple Calendar (CalDAV) ──────────────────────────────────────────────────
# No server-side keys needed — users supply their own Apple ID + App-Specific Password.
# Users generate App-Specific Passwords at: appleid.apple.com → Security → App-Specific Passwords

# ─── Marketing & Communication Hub ───────────────────────────────────────────
# WA Bridge: Node.js service running whatsapp-web.js (see /wa-bridge/)
WA_BRIDGE_URL=http://127.0.0.1:3099

# Node Mailer service (existing backend/ email service)
NODE_MAILER_URL=http://localhost:3000

# SMSGatewayHub credentials (stored in DB via UI, but can seed here)
# SMS_API_KEY=your_smsgatewayhub_key
# SMS_SENDER_ID=CAOFFICE

# Social Media API (Ayrshare / Buffer / SocialPilot)
# SOCIAL_API_KEY=your_ayrshare_key
# SOCIAL_API_PROVIDER=ayrshare

# WA Business API (Interakt / Gupshup / Twilio)
# WA_NATIVE_API_KEY=your_interakt_key
# WA_NATIVE_PROVIDER=interakt

# ─── AI Blog Generation ───────────────────────────────────────────────────────
# OpenAI credentials for GPT-5.1 blog drafts + DALL-E 3 cover images
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_IMAGE_MODEL=dall-e-3

# Public marketing site URL (used in blog email blast links)
# Local dev: http://localhost:5174  |  Production: https://carahulgupta.in
MARKETING_SITE_URL=http://localhost:5174

# Max PHP execution time (seconds) during blog email blasts (fallback if the host allows set_time_limit).
# Sends use concurrent Brevo requests; omit or set 0 to leave PHP defaults unchanged. Default when unset in code: 600.
# BLOG_EMAIL_MAX_SECONDS=600
