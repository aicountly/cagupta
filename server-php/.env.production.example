APP_ENV=production
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY
# BASE_URL must match the live API domain (update if the domain changes)
BASE_URL=https://carahulgupta.in/api

DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=REPLACE_WITH_DB_PASSWORD

JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
TOKEN_TTL_HOURS=8

# Browser Origins allowed to call this API (comma-separated, no spaces required).
# Put the portal first (used by Zoom postMessage). Apex + www optional if they load the SPA.
# Example: portal on app subdomain, API URL on apex https://carahulgupta.in/api
CORS_ORIGIN=https://app.carahulgupta.in,https://carahulgupta.in,https://www.carahulgupta.in

BREVO_API_KEY=REPLACE_WITH_BREVO_API_KEY
SENDER_EMAIL=office@carahulgupta.in
SENDER_NAME=CA Rahul Gupta Office
SUPERADMIN_NOTIFY_EMAIL=rahul@cagupta.in

# Quotation catalog changes (Settings) require this passphrase + email OTP
QUOTATION_SETUP_PASSPHRASE=REPLACE_WITH_STRONG_SECRET

# Razorpay — register webhook: {BASE_URL}/webhooks/razorpay (event: payment.captured)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Zoom OAuth — redirect URL must match Zoom app settings (default {BASE_URL}/integrations/zoom/callback)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
ZOOM_STATE_SECRET=REPLACE_WITH_LONG_RANDOM_STRING