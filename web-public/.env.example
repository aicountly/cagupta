# Public-facing marketing site environment variables.
# Copy this file to `.env` and adjust as needed.

# Base URL of the existing React portal (cPanel subdomain in production).
# In dev, point at the local Vite server for the portal (e.g. http://localhost:5173).
VITE_PORTAL_URL=https://app.carahulgupta.in

# PHP API base URL — only needed for LOCAL DEVELOPMENT.
# In production, web-public and the API share the same origin (carahulgupta.in),
# so the code defaults to the relative path /api automatically — no env var required.
#
# For local dev where the PHP backend runs on a different port:
# VITE_API_BASE_URL=http://localhost:8080/api
