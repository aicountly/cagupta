# Public marketing site (carahulgupta.in)
#
# Shared .env with the office portal: copy web/.env.example to web-public/.env
# (same file in both folders). Marketing build uses VITE_GA4_MARKETING_MEASUREMENT_ID;
# portal build (web/) uses VITE_GA4_PORTAL_MEASUREMENT_ID.

# Portal login links in the navbar dropdown
VITE_PORTAL_URL=https://app.carahulgupta.in

# PHP API — local dev only (production uses /api on the same origin)
# VITE_API_BASE_URL=http://localhost:8080/api

# GA4 — marketing property (carahulgupta.in). See web/.env.example for full list.
VITE_GA4_MARKETING_MEASUREMENT_ID=
VITE_GA4_PORTAL_MEASUREMENT_ID=
# VITE_GA4_MEASUREMENT_ID=
